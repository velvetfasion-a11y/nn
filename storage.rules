rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /product-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && (request.auth.uid == "CXikFopbqfdKUy98g6gj9H6j2412"
            || request.auth.token.email == "contact@jamiljamila.com");
    }
  }
}
