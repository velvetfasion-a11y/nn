VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Admin panel access (browser + server — ADMIN_* is exposed to Vite via envPrefix)
ADMIN_EMAIL=contact@jamiljamila.com
ADMIN_UID=
ADMIN_PAGE=jamiljamila-admin.html
ADMIN_PAGES=admin.html,jamiljamila-admin.html

# MailerSend API (server-side only — do not prefix with VITE_)
# Create token: MailerSend → Settings → API tokens (Full access → Email)
MAILERSEND_API_TOKEN=
MAILERSEND_VERIFICATION_TEMPLATE_ID=
MAILERSEND_FROM_EMAIL=info@jamiljamila.com
MAILERSEND_FROM_NAME=Jamil Jamila
MAILERSEND_VERIFICATION_SUBJECT=Grattis — Du är med! | Jamil Jamila
MAILERSEND_ADMIN_EMAIL=contact@jamiljamila.com
MAILERSEND_ADMIN_FROM_EMAIL=info@jamiljamila.com
MAILERSEND_ADMIN_FROM_NAME=Jamil Jamila System
MAILERSEND_ADMIN_SUBJECT=Ny prenumerant! | Intern Notis
API_PORT=3001

# Production custom domain (GitHub Pages + CNAME)
# After deploy, add jamiljamila.com and www.jamiljamila.com in Firebase Console →
# Authentication → Settings → Authorized domains.
# Run npm run sync:admin before deploy to refresh js/*.public.js from this file.
